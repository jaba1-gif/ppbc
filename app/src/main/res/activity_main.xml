<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="定点打卡得红包"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvAccStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无障碍服务：未知"
            android:textColor="#D32F2F"
            android:paddingBottom="12dp"/>

        <!-- 使用期 / 卡密 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#FFF7F7"
            android:padding="12dp">
            <TextView android:id="@+id/tvRemain" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="使用期限：--"
                android:textStyle="bold" android:textColor="#E53935"/>
            <TextView android:id="@+id/tvDevice" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="设备码：--"
                android:textSize="13sp" android:paddingTop="4dp"/>
            <Button android:id="@+id/btnCopyDevice" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="复制设备码"
                android:textSize="12sp" android:minHeight="0dp" android:paddingVertical="4dp"/>
            <EditText android:id="@+id/etCard" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="输入月卡卡密激活"
                android:layout_marginTop="4dp"/>
            <Button android:id="@+id/btnActivate" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="激活卡密"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- 权限按钮 -->
        <Button android:id="@+id/btnAcc" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="① 开启无障碍服务（必须）"/>
        <Button android:id="@+id/btnBattery" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="② 关闭电池优化（不限制）"/>
        <Button android:id="@+id/btnExactAlarm" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="③ 允许准时闹钟提醒"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginVertical="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="目标App包名" android:textStyle="bold"/>
        <EditText android:id="@+id/etPkg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="com.cptc.xxx"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="签到时间"/>
                <EditText android:id="@+id/etInTime" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="08:30"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="签退时间"/>
                <EditText android:id="@+id/etOutTime" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="18:00"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="打开App后等待秒数" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/etOpenWait" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="number" android:hint="4"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginVertical="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="界面文字（按目标App实际显示填写）" android:textStyle="bold"/>
        <EditText android:id="@+id/etWork" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="工作"/>
        <EditText android:id="@+id/etMorning" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="上午（签到所在行标识）"/>
        <EditText android:id="@+id/etAfternoon" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="下午（签退所在行标识）"/>
        <EditText android:id="@+id/etIn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="签到"/>
        <EditText android:id="@+id/etOut" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="签退"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginVertical="12dp"/>

        <Switch android:id="@+id/swAuto" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="启用自动打卡"/>
        <Switch android:id="@+id/swIn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="启用自动签到"/>
        <Switch android:id="@+id/swOut" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="启用自动签退"/>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="保存设置"
            android:layout_marginTop="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnTestIn" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="立即测试签到"/>
            <Button android:id="@+id/btnTestOut" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="立即测试签退"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_marginVertical="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="运行记录" android:textStyle="bold"/>
            <Button android:id="@+id/btnClearLog" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="清空"/>
        </LinearLayout>
        <TextView android:id="@+id/tvLog" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:fontFamily="monospace" android:paddingTop="4dp"
            android:text=""/>

    </LinearLayout>
</ScrollView>
